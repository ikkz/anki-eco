{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["**/dist/**", "**/coverage/**", ".nx/cache/**", ".nx/workspace-data/**"],
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "react",
    "react-perf",
    "oxc",
    "import",
    "vue",
    "vitest"
  ],
  "options": {
    "typeAware": true
  }
}
